# Advanced mode only.
# Normal setup saves structured settings to ./data/service/runtime-settings.json
# and generates ./data/service/runtime.env automatically.
# Create a local .env only when you intentionally need manual overrides.
EDGE_CONTROL_URL=https://edge.autonomousc.com
# For local Worker development, override with http://host.docker.internal:8787
EDGE_CONTROL_FALLBACK_URLS=
# Legacy fallback only. Leave empty for the browser-assisted node claim flow.
OPERATOR_TOKEN=
NODE_LABEL=AUTONOMOUSc Nordic Node 01
NODE_REGION=eu-se-1
TRUST_TIER=restricted
RESTRICTED_CAPABLE=true
CREDENTIALS_PATH=/var/lib/autonomousc/credentials/node-credentials.json
AUTOPILOT_STATE_PATH=/var/lib/autonomousc/scratch/autopilot-state.json
HEAT_GOVERNOR_STATE_PATH=/var/lib/autonomousc/scratch/heat-governor-state.json
CONTROL_PLANE_STATE_PATH=/var/lib/autonomousc/scratch/control-plane-state.json
FAULT_INJECTION_STATE_PATH=/var/lib/autonomousc/scratch/fault-injection-state.json
STARTUP_STATUS_PATH=/var/lib/autonomousc/scratch/startup-status.json
STARTUP_STATUS_HOST=0.0.0.0
# Set STARTUP_STATUS_PORT=0 to disable the HTTP status endpoint and keep only the JSON file.
STARTUP_STATUS_PORT=8011
STARTUP_STATUS_ENDPOINT_PATH=/startup-status
RUNTIME_PROFILE=auto
DEPLOYMENT_TARGET=home_edge
INFERENCE_ENGINE=llama_cpp
RUNTIME_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
CAPACITY_CLASS=home_heat
TEMPORARY_NODE=false
BURST_PROVIDER=
BURST_LEASE_ID=
BURST_LEASE_PHASE=
BURST_COST_CEILING_USD=
INFERENCE_BASE_URL=http://inference-runtime:8000
# Deprecated compatibility alias. Prefer INFERENCE_BASE_URL.
VLLM_BASE_URL=http://inference-runtime:8000
GPU_NAME=RTX 4090
GPU_MEMORY_GB=24
MAX_CONTEXT_TOKENS=32768
MAX_BATCH_TOKENS=50000
MAX_CONCURRENT_ASSIGNMENTS=2
# Active runtime concurrency and local backlog are intentionally separate.
# Leave these empty to let the node derive safe defaults from VRAM/model profile.
MAX_CONCURRENT_ASSIGNMENTS_EMBEDDINGS=
MAX_MICROBATCH_ASSIGNMENTS_EMBEDDINGS=
MAX_LOCAL_QUEUE_ASSIGNMENTS=
PULL_BUNDLE_SIZE=16
CONTROL_PLANE_GRACE_SECONDS=180
CONTROL_PLANE_RETRY_FLOOR_SECONDS=3
CONTROL_PLANE_RETRY_CAP_SECONDS=30
ARTIFACT_MIRROR_BASE_URLS=
MODEL_CACHE_BUDGET_GB=
MODEL_CACHE_RESERVE_FREE_GB=
# Optional local bundle with runtime image archives and starter-model cache.
OFFLINE_INSTALL_BUNDLE_DIR=
HEAT_GOVERNOR_MODE=100
OWNER_OBJECTIVE=balanced
TARGET_GPU_UTILIZATION_PCT=100
MIN_GPU_MEMORY_HEADROOM_PCT=20
THERMAL_HEADROOM=0.8
HEAT_DEMAND=high
ROOM_TEMP_C=
TARGET_TEMP_C=
OUTSIDE_TEMP_C=
QUIET_HOURS_START_LOCAL=
QUIET_HOURS_END_LOCAL=
GPU_TEMP_C=
GPU_TEMP_LIMIT_C=82
POWER_WATTS=
ESTIMATED_HEAT_OUTPUT_WATTS=
GPU_POWER_LIMIT_ENABLED=true
MAX_POWER_CAP_WATTS=
ENERGY_PRICE_KWH=
SUPPORTED_MODELS=meta-llama/Llama-3.1-8B-Instruct,BAAI/bge-large-en-v1.5
POLL_INTERVAL_SECONDS=10
ATTESTATION_PROVIDER=simulated
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
LLAMA_CPP_HF_REPO=bartowski/Meta-Llama-3.1-8B-Instruct-GGUF
LLAMA_CPP_HF_FILE=Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf
LLAMA_CPP_ALIAS=meta-llama/Llama-3.1-8B-Instruct
LLAMA_CPP_EMBEDDING=false
LLAMA_CPP_POOLING=
# Optional Hugging Face token for gated startup models.
HUGGING_FACE_HUB_TOKEN=
HF_TOKEN=
# Single-container smoke testing: RUN_MODE=serve_only skips the node agent and
# only validates that the local inference runtime can warm and serve requests.
RUN_MODE=full
START_NODE_AGENT=true
# Legacy alias for older compose releases. Prefer RUNTIME_IMAGE.
VLLM_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
