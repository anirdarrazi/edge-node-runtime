FROM docker:27-cli

RUN apk add --no-cache python3 py3-pip py3-setuptools py3-wheel

WORKDIR /app

COPY pyproject.toml /app/pyproject.toml
COPY src /app/src

RUN python3 -m pip install --no-cache-dir .

ENV AUTONOMOUSC_RUNTIME_DIR=/var/lib/autonomousc/manager
ENV AUTONOMOUSC_RUNTIME_HOST=host.docker.internal

EXPOSE 8765

CMD ["node-agent-service", "run", "--host", "0.0.0.0", "--port", "8765"]
