ARG VLLM_BASE_IMAGE=vllm/vllm-openai@sha256:d9a5c1c1614c959fde8d2a4d68449db184572528a6055afdd0caf1e66fb51504
FROM docker:27-cli AS docker-cli

ARG VLLM_BASE_IMAGE
FROM ${VLLM_BASE_IMAGE}

WORKDIR /app

COPY --from=docker-cli /usr/local/bin/docker /usr/local/bin/docker
COPY --from=docker-cli /usr/local/libexec/docker/cli-plugins/docker-compose /usr/local/libexec/docker/cli-plugins/docker-compose

COPY pyproject.toml /app/pyproject.toml
COPY src /app/src

RUN mkdir -p /usr/local/libexec/docker/cli-plugins \
    && ln -sf /usr/bin/python3 /usr/local/bin/python \
    && python3 -m pip install --no-cache-dir --upgrade pip \
    && python3 -m pip install --no-cache-dir .

ENV AUTONOMOUSC_ALLOW_CONTAINER_BIND=true
ENV AUTONOMOUSC_RUNTIME_DIR=/var/lib/autonomousc
ENV INFERENCE_BASE_URL=http://127.0.0.1:8000
ENV VLLM_BASE_URL=http://127.0.0.1:8000
ENV VLLM_HOST=0.0.0.0
ENV VLLM_PORT=8000
ENV HF_HOME=/var/lib/autonomousc/data/model-cache
ENV CREDENTIALS_PATH=/var/lib/autonomousc/data/credentials/node-credentials.json
ENV ATTESTATION_STATE_PATH=/var/lib/autonomousc/data/credentials/attestation-state.json
ENV RECOVERY_NOTE_PATH=/var/lib/autonomousc/data/credentials/recovery-note.txt
ENV AUTOPILOT_STATE_PATH=/var/lib/autonomousc/data/scratch/autopilot-state.json

EXPOSE 8765 8000

ENTRYPOINT ["node-agent-launcher"]
